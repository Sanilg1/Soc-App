rules_version = '2';
 
service cloud.firestore {
  match /databases/{database}/documents {
 
    // ──────────────────────────────────────
    // Helper Functions
    // ──────────────────────────────────────
 
    function isAuthenticated() {
      return request.auth != null;
    }
 
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
 
    function getUserFlatId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.flatId;
    }
 
    function isResident() {
      return isAuthenticated() && getUserRole() == 'resident';
    }
 
    function isWorker() {
      return isAuthenticated() && getUserRole() == 'worker';
    }
 
    function isAdmin() {
      // Allow write if user is authenticated AND exists in 'users' collection with role 'admin'
      // OR exists in 'admins' collection
      return request.auth != null && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
 
    function isGuard() {
      return isAuthenticated() && getUserRole() == 'guard';
    }
 
    function getWorkerCategory() {
      return get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.category;
    }
 
    // ──────────────────────────────────────
    // Users Collection
    // ──────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
 
    // ──────────────────────────────────────
    // Flats Collection
    // ──────────────────────────────────────
    match /flats/{flatId} {
      allow read: if true;
      allow write: if isAdmin();
    }
 
    // ──────────────────────────────────────
    // Complaints Collection
    // ──────────────────────────────────────
    match /complaints/{complaintId} {
      // Allow reads for admin dashboard (simulated auth)
      // and authenticated residents/workers
      allow read: if true;
 
      // Residents can create complaints for their own flat
      allow create: if isResident() && request.resource.data.flatId == getUserFlatId();
 
      // Workers, residents, admins can update
      allow update: if isAuthenticated();
 
      // Only admins can delete complaints
      allow delete: if isAdmin();
    }
 
    // ──────────────────────────────────────
    // Society Issues Collection
    // ──────────────────────────────────────
    match /society_issues/{issueId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
 
    // ──────────────────────────────────────
    // Workers Collection
    // ──────────────────────────────────────
    match /workers/{workerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
 
    // ──────────────────────────────────────
    // Admins Collection
    // ──────────────────────────────────────
    match /admins/{adminId} {
      allow read: if true;
      allow create: if request.resource.data.secret == '123456';
      allow update, delete: if isAdmin();
    }
 
    // ──────────────────────────────────────
    // Guards Collection
    // ──────────────────────────────────────
    match /guards/{guardId} {
      allow read: if true;
      allow write: if isAdmin();
    }
 
    // ──────────────────────────────────────
    // Notifications Collection
    // ──────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if true;
      allow update: if true;
      allow create, delete: if true;
    }
 
    // ──────────────────────────────────────
    // Leave Requests Collection
    // ──────────────────────────────────────
    match /leave_requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
 
    // ──────────────────────────────────────
    // Escalations Collection
    // ──────────────────────────────────────
    match /escalations/{escalationId} {
      allow read: if true;
      allow create, update, delete: if true;
    }
 
    // ──────────────────────────────────────
    // Activity Logs Collection
    // ──────────────────────────────────────
    match /activity_logs/{logId} {
      allow read: if true;
      allow create, update, delete: if true;
    }
 
    // ──────────────────────────────────────
    // Flat Ledgers Collection
    // ──────────────────────────────────────
    match /flat_ledgers/{flatId} {
      allow read: if true;
      allow write: if true;
    }
 
    // ──────────────────────────────────────
    // Notices Collection
    // ──────────────────────────────────────
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
