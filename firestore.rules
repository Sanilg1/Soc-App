rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────
    // Helper Functions
    // ──────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function getUserFlatId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.flatId;
    }

    function isResident() {
      return isAuthenticated() && getUserRole() == 'resident';
    }

    function isWorker() {
      return isAuthenticated() && getUserRole() == 'worker';
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.phone_number == '+919818557372' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isGuard() {
      return isAuthenticated() && getUserRole() == 'guard';
    }

    function getWorkerCategory() {
      return get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.category;
    }

    // ──────────────────────────────────────
    // Users Collection
    // ──────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Admins have full write access
      allow write: if isAdmin();
      // Users can update their own profile, but CANNOT change their role
      allow update: if request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      // Users can create their own doc during registration (role set by backend)
      allow create: if request.auth.uid == userId
        && request.resource.data.role == 'resident';
    }

    // ──────────────────────────────────────
    // Flats Collection
    // ──────────────────────────────────────
    match /flats/{flatId} {
      // Any authenticated user can read flats (needed for invite verification during registration)
      allow read: if true; // Changed to true to allow unauthenticated invite verification
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────
    // Complaints Collection
    // ──────────────────────────────────────
    match /complaints/{complaintId} {
      // Residents can read only their own flat's complaints
      // Workers can read complaints in their assigned category
      // Admins can read all complaints
      allow read: if isAuthenticated() && (
        (isResident() && resource.data.flatId == getUserFlatId()) ||
        (isWorker() && resource.data.category == getWorkerCategory()) ||
        isAdmin()
      );

      // Residents can create complaints for their own flat
      allow create: if isResident() && request.resource.data.flatId == getUserFlatId();

      // Workers can update complaints in their category
      // Residents can update their own flat's complaints (reopen, confirm)
      // Admins can update any complaint
      allow update: if isAuthenticated() && (
        (isResident() && resource.data.flatId == getUserFlatId()) ||
        (isWorker() && resource.data.category == getWorkerCategory()) ||
        isAdmin()
      );

      // Only admins can delete complaints
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────
    // Society Issues Collection
    // ──────────────────────────────────────
    match /society_issues/{issueId} {
      // All authenticated users can read society issues (public)
      allow read: if isAuthenticated();

      // Residents can create society issues
      allow create: if isResident();

      // Only admins can update/delete society issues
      allow update, delete: if isAdmin();
    }

    // ──────────────────────────────────────
    // Workers Collection
    // ──────────────────────────────────────
    match /workers/{workerId} {
      allow read: if true; // Changed to true to allow unauthenticated worker login verification
      // Admins have full write access
      allow write: if isAdmin();
      // Workers can update their own doc but CANNOT change category, active, or pauseStatus
      allow update: if request.auth.uid == workerId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['category', 'active', 'pauseStatus']));
    }

    // ──────────────────────────────────────
    // Admins Collection
    // ──────────────────────────────────────
    match /admins/{adminId} {
      // Only admins can read admin records (prevents identity/phone leaks)
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────
    // Guards Collection
    // ──────────────────────────────────────
    match /guards/{guardId} {
      allow read: if isAuthenticated() && (request.auth.uid == guardId || isAdmin());
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────
    // Notifications Collection
    // ──────────────────────────────────────
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && resource.data.targetUserId == request.auth.uid;

      // Only Cloud Functions (admin SDK) should create notifications
      // Allow update for marking as read
      allow update: if isAuthenticated() && resource.data.targetUserId == request.auth.uid;

      allow create, delete: if false; // Only via Cloud Functions (admin SDK)
    }

    // ──────────────────────────────────────
    // Leave Requests Collection
    // ──────────────────────────────────────
    match /leave_requests/{requestId} {
      allow read: if isAuthenticated() && (
        (isWorker() && resource.data.workerId == request.auth.uid) ||
        isAdmin()
      );

      // Workers can create their own leave requests
      allow create: if isWorker() && request.resource.data.workerId == request.auth.uid;

      // Admins can update (approve/reject), workers can update their pending requests
      allow update: if isAdmin() || (isWorker() && resource.data.workerId == request.auth.uid && resource.data.status == 'pending');

      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────
    // Escalations Collection
    // ──────────────────────────────────────
    match /escalations/{escalationId} {
      // Admins and guards (for emergency) can read escalations
      allow read: if isAdmin() || (isGuard() && resource.data.type == 'emergency');

      // Only Cloud Functions should create/update escalations
      allow create, update, delete: if false; // Only via Cloud Functions (admin SDK)
    }

    // ──────────────────────────────────────
    // Activity Logs Collection
    // ──────────────────────────────────────
    match /activity_logs/{logId} {
      // Admins can read all logs
      // Residents can read logs for their flat's complaints
      // Workers can read logs for their category's complaints
      allow read: if isAdmin();

      // Only Cloud Functions should create activity logs
      allow create, update, delete: if false; // Only via Cloud Functions (admin SDK)
    }

    // ──────────────────────────────────────
    // Flat Ledgers Collection
    // ──────────────────────────────────────
    match /flat_ledgers/{flatId} {
      // Residents can only read their own ledger
      // Only housekeeping workers (ironing) and Admins can read all ledgers
      allow read: if isAuthenticated() && (
        (isResident() && getUserFlatId() == flatId) ||
        (isWorker() && getWorkerCategory() == 'housekeeping') ||
        isAdmin()
      );
      
      // Only housekeeping workers and Admins can write/update ledgers
      allow write: if isAdmin() || (isWorker() && getWorkerCategory() == 'housekeeping');
    }

    // ──────────────────────────────────────
    // Notices Collection
    // ──────────────────────────────────────
    match /notices/{noticeId} {
      // All authenticated users can read notices
      allow read: if isAuthenticated();
      
      // Only admins can write notices
      allow write: if isAdmin();
    }

    // ──────────────────────────────────────
    // Metadata / Counters
    // ──────────────────────────────────────
    match /metadata/{document} {
      // Authenticated users can read counters (e.g. for displaying IDs)
      allow read: if isAuthenticated();
      // Allow authenticated users to update counters (needed for transaction to generate sequential IDs)
      allow write: if isAuthenticated();
    }

    // ──────────────────────────────────────
    // Visitors Collection
    // ──────────────────────────────────────
    match /visitors/{visitorId} {
      // Residents can read visitors for their own flat
      // Guards and admins can read all visitors
      allow read: if isAuthenticated() && (
        (isResident() && resource.data.flatId == getUserFlatId()) ||
        isGuard() ||
        isAdmin()
      );

      // Guards can create visitor entries
      allow create: if isGuard();

      // Residents can update (approve/deny) their own flat's visitors
      // Guards and admins can update any visitor
      allow update: if isAuthenticated() && (
        (isResident() && resource.data.flatId == getUserFlatId()) ||
        isGuard() ||
        isAdmin()
      );

      // Only admins can delete visitor records
      allow delete: if isAdmin();
    }

    // ──────────────────────────────────────
    // Hall Bookings Collection
    // ──────────────────────────────────────
    match /hall_bookings/{bookingId} {
      // Residents can read their own flat's bookings
      // Admins can read all bookings
      allow read: if isAuthenticated() && (
        (isResident() && resource.data.flatId == getUserFlatId()) ||
        isAdmin()
      );

      // Residents can create bookings for their own flat
      allow create: if isResident() && request.resource.data.flatId == getUserFlatId();

      // Only admins can update (approve/reject) or delete bookings
      allow update, delete: if isAdmin();
    }
  }
}
